<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="#F1F3F5"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_check_circle"
                app:tint="#D97706" />

            <TextView
                android:id="@+id/tvFindingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@+id/ivIcon"
                android:text="Pleural Effusion"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFindingConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="#F3F4F6"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="65.2%"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Location: Left costophrenic angle"
            android:textColor="#4B5563"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Small amount of fluid accumulation detected in the left pleural space."
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/lblConf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confidence Level"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvConfLevelPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="65.2%"
                android:textColor="#4B5563"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/pbConfidence"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_below="@+id/lblConf"
                android:layout_marginTop="4dp"
                android:max="100"
                android:progress="65"
                android:progressDrawable="@drawable/progress_high" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvSeverityTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_fff8e1_rounded"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Low Severity"
            android:textColor="#D97706"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>