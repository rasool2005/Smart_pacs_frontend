<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#F1F3F5" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Background grid lines -->
    <item android:top="20dp" android:bottom="20dp" android:left="10dp" android:right="10dp">
        <shape>
            <stroke android:width="1dp" android:color="#E0E0E0" android:dashWidth="4dp" android:dashGap="4dp" />
        </shape>
    </item>
    <!-- Mock Trend Line -->
    <item android:gravity="center">
        <vector
            android:width="200dp"
            android:height="80dp"
            android:viewportWidth="200"
            android:viewportHeight="80">
            <path
                android:strokeColor="#1E65FF"
                android:strokeWidth="3"
                android:strokeLineCap="round"
                android:strokeLineJoin="round"
                android:pathData="M10,70 L40,60 L70,65 L100,40 L130,45 L160,20 L190,10" />
            <path
                android:fillColor="#331E65FF"
                android:pathData="M10,70 L40,60 L70,65 L100,40 L130,45 L160,20 L190,10 L190,80 L10,80 Z" />
        </vector>
    </item>
</layer-list>